# ============================================================================
# Misc Files
# ============================================================================
.DS_Store
node_modules
.tmp
npm-debug.log

# ============================================================================
# Terraform
# ============================================================================

# Local .terraform directories
**/.terraform/*

# Terraform state files - should be stored in remote backend (S3)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which may contain sensitive data
*.tfvars
*.tfvars.json

# Override files - used for local development customization
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration files
.terraformrc
terraform.rc

# Terraform plan output files
*.tfplan
tfplan

# ============================================================================
# IDE and Editor
# ============================================================================

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs (IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.iws

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-workspace
*.sublime-project

